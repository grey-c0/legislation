/**
 * Digital ID & Surveillance Legislation Research Brief
 * Scope: New Zealand, France, Sweden + EU-level legislation
 * Perspective: Leftist/civil liberties/worker-focused analysis
 * Compiled: March 2025
 * 
 * Severity Scoring Rubric (1-5):
 * +1 Universal application (entire population)
 * +1 Criminal penalties (fines, prison, service ban)
 * +1 Irreversible data collection (biometrics, permanent databases)
 * +1 Chilling effect on organizing (targets worker communication/union activity)
 * +1 Mission creep (explicit expansion to other sectors)
 * +1 No judicial oversight (warrantless access)
 * +1 Digital exclusion (requires smartphone/bank account)
 * 
 * 1-2: Low (Yellow), 3: Medium (Orange), 4-5: High/Extreme (Red)
 */

[
  // ============================================================
  // EU-LEVEL LEGISLATION (Affects all three countries)
  // ============================================================
  
  {
    "id": "EU-2022-CHATCONTROL",
    "commonName": "Chat Control / Child Sexual Abuse Material Regulation (CSAR)",
    "legalName": "Proposal for a Regulation to Prevent and Combat Child Sexual Abuse (2022/0155(COD))",
    "location": "EU",
    "status": "proposed",
    "severity": {
      "score": 5,
      "rationale": "Universal application affecting all EU residents [+1], criminal penalties for non-compliance by platforms [+1], irreversible biometric/AI scanning of all private communications [+1], severe chilling effect on worker organizing and private communications [+1], explicit mission creep from voluntary to mandatory scanning [+1], warrantless mass surveillance without individualized suspicion [+1], digital exclusion through mandatory age verification ending anonymity [+1]. Total: 5/5 (Extreme)"
    },
    "categories": [
      "encryption_backdoor",
      "platform_mandated_scanning",
      "age_verification",
      "biometric_collection"
    ],
    "jurisdiction": "Union",
    "description": "Would mandate client-side scanning of all private messages, emails, and cloud content before encryption, effectively breaking end-to-end encryption. Forces platforms to scan for CSAM using AI and hash matching, with mandatory age verification eliminating anonymous communication. Creates infrastructure for mass surveillance disguised as child protection.",
    "sources": [
      {
        "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:52022PC0204",
        "type": "primary",
        "description": "European Commission Proposal Text - Official legislative proposal"
      },
      {
        "url": "https://www.patrick-breyer.de/en/posts/chat-control/",
        "type": "civil_society",
        "description": "Patrick Breyer (MEP, Greens/EFA) - Digital rights analysis and campaign documentation"
      },
      {
        "url": "https://techpolicy.press/how-europes-chat-control-regulation-could-compromise-american-communications",
        "type": "civil_society",
        "description": "Tech Policy Press analysis of client-side scanning and encryption backdoors"
      },
      {
        "url": "https://edps.europa.eu/data-protection/our-work/publications/opinions/european-data-protection-supervisor-and-european-data-protection-board-joint-opinion-22022_en",
        "type": "civil_society",
        "description": "EDPS/EDPB Joint Opinion warning of 'de facto generalized and indiscriminate scanning'"
      }
    ],
    "notes": "TRILOGUE NEGOTIATIONS ONGOING as of March 2025. Council position (Nov 2025) removed mandatory detection orders but keeps 'voluntary' scanning and risk mitigation framework. Parliament position protects encryption. Germany, Netherlands, Austria, Poland opposed mandatory scanning. 230+ civil society organizations signed open letter opposing. European Parliament study found 80% false positive rates in some jurisdictions. Timeline: Final vote expected mid-2026. If passed, takes immediate binding effect across all 27 member states without national implementing legislation."
  },
  
  {
    "id": "EU-2024-EIDAS2",
    "commonName": "eIDAS 2.0 / European Digital Identity Wallet",
    "legalName": "Regulation (EU) 2024/1183 amending Regulation (EU) No 910/2014 (eIDAS 2.0)",
    "location": "EU",
    "status": "implementing",
    "severity": {
      "score": 4,
      "rationale": "Universal application for all EU citizens/residents who request wallets [+1], no direct criminal penalties but exclusion from services [+0.5], irreversible biometric collection for wallet authentication [+1], chilling effect through cross-sector activity linking [+1], mission creep to private sector services explicit in text [+1], government-controlled certificate authorities create surveillance risk [+0.5], digital exclusion for those without smartphones [+0.5]. Total: 4/5 (High)"
    },
    "categories": [
      "digital_id",
      "biometric_collection"
    ],
    "jurisdiction": "Union",
    "description": "Mandates EU member states issue digital identity wallets to citizens and residents for cross-border authentication. Contains controversial Article 45 requiring browsers to trust government-approved certificate authorities (QWACs), potentially enabling man-in-the-middle attacks and government interception. Creates centralized identity infrastructure linking health, finance, and travel data.",
    "sources": [
      {
        "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:32024R1183",
        "type": "primary",
        "description": "Official eIDAS 2.0 Regulation Text - EU Official Journal"
      },
      {
        "url": "https://europeanpirates.eu/digital-convenience-vs-digital-control-rethinking-the-eu-identity-wallet/",
        "type": "civil_society",
        "description": "European Pirate Party analysis of surveillance and control risks"
      },
      {
        "url": "https://www.eff.org/deeplinks/2022/12/eidas-20-sets-dangerous-precedent-web-security",
        "type": "civil_society",
        "description": "Electronic Frontier Foundation warning on browser security risks and QWACs"
      },
      {
        "url": "https://www.rstreet.org/research/cybersecurity-score-european-union-electronic-identification-authentication-and-trust-services-eidas-2-0/",
        "type": "civil_society",
        "description": "R Street Institute cybersecurity analysis of Article 45 vulnerabilities"
      }
    ],
    "notes": "Adopted April 2024, full implementation by 2026. 500+ signatories on open letter expressing concerns about profiling and government interception. Article 45.2 mandates browsers trust government-designated CAs even if unsafe - browsers cannot unilaterally revoke. Creates 'digital sovereignty' framework that could enable mass surveillance. Pilot programs ongoing. Member states must provide wallets by 2026. Non-discrimination clause included but de facto mandatory through service provider adoption."
  },

