  {
    "id": "NZ-2023-DIGID",
    "commonName": "Digital Identity Services Trust Framework",
    "legalName": "Digital Identity Services Trust Framework Act 2023",
    "location": "New Zealand",
    "status": "active",
    "severity": {
      "score": 3,
      "rationale": "Voluntary accreditation system [+0], no criminal penalties for users [+0], biometric data collection by accredited providers [+0.5], potential chilling effect if widely adopted [+0.5], mission creep to employment and services possible [+0.5], some judicial oversight through Privacy Commissioner [+0], digital exclusion risk for those without technology access [+0.5]. Total: 3/5 (Medium)"
    },
