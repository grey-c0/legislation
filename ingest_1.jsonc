    "location": "New Zealand",
    "status": "implementing",
    "severity": {
      "score": 3,
      "rationale": "Applies to all organizations using biometric processing [+1], no criminal penalties but compliance orders possible [+0.5], irreversible biometric collection regulated but not prohibited [+0.5], explicit recognition of chilling effect on protests in Code text [+1], mission creep to emotion detection and attention tracking partially restricted [+0.5], oversight through Privacy Commissioner [+0], digital exclusion concerns acknowledged [+0.5]. Total: 3/5 (Medium)"
    },
