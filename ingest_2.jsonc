/**
 * Digital ID & Surveillance Legislation Research Brief
 * Scope: Netherlands, Ireland, Belgium + EU-level legislation
 * Perspective: Leftist/civil liberties/worker-focused analysis
 * Compiled: March 2026
 * 
 * Severity Scoring Rubric (1-5):
 * +1 Universal application (entire population)
 * +1 Criminal penalties (fines, prison, service ban)
 * +1 Irreversible data collection (biometrics, permanent databases)
 * +1 Chilling effect on organizing (targets worker communication/union activity)
 * +1 Mission creep (explicit expansion to other sectors)
 * +1 No judicial oversight (warrantless access)
 * +1 Digital exclusion (requires smartphone/bank account)
 * 
 * 1-2: Low (Yellow), 3: Medium (Orange), 4-5: High/Extreme (Red)
 */

[
  // ==================== EU-LEVEL LEGISLATION ====================
  {
    "id": "EU-2024-EIDAS2",
    "commonName": "eIDAS 2.0 / European Digital Identity Wallet",
    "legalName": "Regulation (EU) 2024/1183 amending Regulation (EU) No 910/2014",
    "location": "EU",
    "status": "implementing",
    "severity": {
      "score": 4,
      "rationale": "Universal application for all EU citizens [+1], biometric collection for high-assurance wallets [+1], mission creep to private sector (banks, platforms mandatory acceptance by 2027) [+1], digital exclusion risks for those without smartphones [+1]. No criminal penalties or judicial oversight issues directly. Total: 4/5"
    },
    "categories": ["digital_id", "biometric_collection"],
    "jurisdiction": "Union",
    "description": "Mandates all EU member states provide digital identity wallets by December 2026, with mandatory acceptance by banks, VLOPs, and critical infrastructure by December 2027. Creates universal digital ID infrastructure with biometric verification requirements.",
    "sources": [
      {
        "url": "https://eur-lex.europa.eu/eli/reg/2024/1183",
        "type": "primary",
        "description": "Official EU Regulation text - eIDAS 2.0 amending Regulation (EU) No 910/2014"
      },
      {
        "url": "https://edps.europa.eu/data-protection/our-work/publications/techdispatch/2025-12-15-techdispatch-32025-digital-identity-wallets",
        "type": "civil_society",
        "description": "European Data Protection Supervisor TechDispatch on Digital Identity Wallets - privacy concerns"
      },
      {
        "url": "https://www.dock.io/post/eidas-2",
        "type": "news",
        "description": "eIDAS 2.0 implementation timeline and mandatory acceptance requirements"
      }
    ],
    "notes": "Major concerns from civil liberties perspective: (1) Creates infrastructure for universal digital tracking; (2) 80% adoption target by 2030 effectively makes it quasi-mandatory; (3) Biometric verification at 'high assurance level' enables mass surveillance; (4) Mission creep explicit - starts with public services, expands to banking, telecom, healthcare, education, and Very Large Online Platforms; (5) No clear sunset clauses or limitations on data linkage. Corporate beneficiaries: Signicat, Yoti, and other identity verification vendors. Large-scale pilots (DC4EU, EWC, NOBID) testing cross-border use cases. Opposition: EDPS has raised concerns about data protection by design."
  },
  {
    "id": "EU-2022-CHATCONTROL",
    "commonName": "Chat Control / CSA Regulation (Child Sexual Abuse Material Detection)",
    "legalName": "Proposal for a Regulation to Prevent and Combat Child Sexual Abuse (COM/2022/209 final)",
    "location": "EU",
    "status": "challenged",
    "severity": {
      "score": 5,
      "rationale": "Universal application (all email/messenger providers) [+1], criminal penalties for non-compliance [+1], irreversible data collection (scanning all private communications) [+1], no judicial oversight (automated scanning without warrant) [+1], destroys encryption via client-side scanning [+1], mission creep to 'upload moderation' expanding scope [+1]. Total exceeds 5 - maximum severity."
    },
    "categories": ["encryption_backdoor", "platform_mandated_scanning", "data_retention"],
    "jurisdiction": "Union",
    "description": "Proposes mandatory scanning of all private digital communications (emails, messages, chats) for CSAM detection, including end-to-end encrypted services via client-side scanning. Would effectively ban secure encryption and establish mass surveillance infrastructure.",
    "sources": [
      {
        "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:52022PC0209",
        "type": "primary",
        "description": "European Commission proposal for CSA Regulation (Chat Control)"
      },
      {
        "url": "https://www.patrick-breyer.de/en/posts/chat-control/",
        "type": "civil_society",
        "description": "Patrick Breyer (MEP) comprehensive analysis of Chat Control dangers - digital rights perspective"
      },
      {
        "url": "https://edri.org/our-work/mass-surveillance-of-telecommunications-document-pool/",
        "type": "civil_society",
        "description": "EDRi (European Digital Rights) document pool on mass surveillance and Chat Control"
      }
    ],
    "notes": "CRITICAL THREAT TO ENCRYPTION. Current status: Council negotiations ongoing, Danish presidency backed down from mandatory scanning in October 2025 after public pressure. Germany, Netherlands, Poland, Austria opposed. European Parliament LIBE Committee voted to exclude end-to-end encryption. However, 'backdoor attempt' via 'upload moderation' wording being pushed. Interim 'Chat Control 1.0' (voluntary scanning) extended until April 2026. Opposition: 80%+ of consultation respondents opposed. European Data Protection Supervisor condemned proposal. European Parliament study found high false-positive rates. Corporate beneficiaries: Thorn, Microsoft PhotoDNA providers, AI scanning vendors. Workers' concern: Destroys secure worker communication channels, enables employer surveillance of union organizing."
  },
  {
    "id": "EU-2024-PLATFORM-WORK",
    "commonName": "Platform Work Directive (Algorithmic Management Regulation)",
    "legalName": "Directive (EU) 2024/2831 on improving working conditions in platform work",
    "location": "EU",
    "status": "passed",
    "severity": {
      "score": 3,
      "rationale": "Worker surveillance provisions are significant [+1 for chilling effect on organizing], biometric collection prohibited except for authentication [partial +0.5], no universal application (only platform workers) [0], no criminal penalties for workers [0], some judicial oversight via human review requirements [0]. Mixed legislation - includes protections but normalizes surveillance infrastructure. Total: 3/5"
    },
    "categories": ["worker_surveillance", "biometric_collection"],
    "jurisdiction": "Union",
    "description": "Regulates algorithmic management of platform workers including automated monitoring, performance evaluation, and decision-making. Establishes employment presumption and requires human oversight of algorithmic decisions affecting workers.",
    "sources": [
      {
        "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=OJ:L_202402831",
        "type": "primary",
        "description": "Official EU Directive (EU) 2024/2831 text"
      },
      {
        "url": "https://www.consilium.europa.eu/en/policies/platform-work-eu/",
        "type": "primary",
        "description": "Council of the EU - Platform Work Directive overview"
      },
      {
        "url": "https://cms-lawnow.com/en/ealerts/2026/03/from-gig-to-guarantee-how-the-eu-is-transforming-platform-work",
        "type": "civil_society",
        "description": "Worker-focused analysis of Platform Work Directive provisions"
      }
    ],
    "notes": "Mixed bag from workers' rights perspective. POSITIVE: (1) Rebuttable presumption of employment status; (2) Bans processing emotional/psychological state data, private conversations, trade union prediction data; (3) Requires human oversight with authority to override automated decisions; (4) Mandates algorithmic impact assessments every 2 years; (5) Protects oversight staff from retaliation. CONCERNING: (1) Normalizes pervasive worker surveillance as default; (2) 'Business users' exception may exclude many workers; (3) Member states have until December 2026 to implement - weak enforcement timeline; (4) Biometric data still allowed for authentication; (5) Location/behavior tracking still permitted during work. Union positions: Generally supportive but criticised as 'watered down'. ETUC (European Trade Union Confederation) campaigned for stronger provisions."
  },
  {
    "id": "EU-2024-DSA",
    "commonName": "Digital Services Act (DSA)",
    "legalName": "Regulation (EU) 2022/2065 (Digital Services Act)",
    "location": "EU",
    "status": "active",
    "severity": {
      "score": 3,
      "rationale": "Universal application for VLOPs (45M+ users) [+1], data retention for content moderation [+0.5], platform mandated scanning for illegal content [+0.5], no criminal penalties for users [0], some judicial oversight via transparency requirements [0], mission creep to algorithmic accountability [+0.5]. Primarily corporate accountability with surveillance implications. Total: 3/5"
    },
    "categories": ["platform_mandated_scanning", "data_retention"],
    "jurisdiction": "Union",
    "description": "Comprehensive regulation of online platforms requiring content moderation systems, transparency reports, risk assessments, and algorithmic accountability for Very Large Online Platforms (VLOPs).",
    "sources": [
      {
        "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:32022R2065",
        "type": "primary",
        "description": "Official EU Digital Services Act Regulation text"
      },
      {
        "url": "https://commission.europa.eu/news-and-media/news/digital-services-act-keeping-us-safe-online-2025-09-22_en",
        "type": "primary",
        "description": "European Commission DSA enforcement updates"
      },
      {
        "url": "https://edri.org/our-work/mass-surveillance-of-telecommunications-document-pool/",
        "type": "civil_society",
        "description": "EDRi analysis of DSA surveillance implications"
      }
    ],
    "notes": "DSA is primarily corporate accountability legislation but has surveillance dimensions. VLOPs must: (1) Maintain content moderation systems scanning user content; (2) Retain data for transparency reporting; (3) Provide data access to 'vetted researchers' (potential surveillance vector); (4) Algorithmic transparency for recommender systems. Enforcement: Fines up to 6% global turnover. Active investigations against TikTok, AliExpress, Temu, Facebook, Instagram. From leftist perspective: Positive for platform accountability but creates surveillance infrastructure through mandatory content scanning. Workers' concern: Platform workers (content moderators) face traumatic working conditions; algorithmic management of gig workers intersects with DSA transparency requirements."
  },
  {
    "id": "EU-2025-DATA-RETENTION",
    "commonName": "EU Data Retention Framework (Proposed Update)",
    "legalName": "ProtectEU Internal Security Strategy - Data Retention Roadmap",
    "location": "EU",
    "status": "proposed",
    "severity": {
      "score": 4,
      "rationale": "Universal application (all telecommunications users) [+1], no judicial oversight for retention (ministerial order) [+1], irreversible data collection (metadata databases) [+1], mission creep from 'serious crime' to 'national security' [+1], digital exclusion not applicable [0], criminal penalties for providers [+0.5]. Total: 4.5/5 rounded to 4/5"
    },
    "categories": ["data_retention", "traffic_retention"],
    "jurisdiction": "Union",
    "description": "Proposed update to EU data retention rules following CJEU rulings. Would reintroduce mass telecommunications metadata retention for law enforcement access, with impact assessment expected Q1 2026.",
    "sources": [
      {
        "url": "https://commission.europa.eu/strategy-and-policy/policies/justice-and-fundamental-rights/policies-internal-security/protecteu_en",
        "type": "primary",
        "description": "European Commission ProtectEU Internal Security Strategy"
      },
      {
        "url": "https://edri.org/our-work/mass-surveillance-of-telecommunications-document-pool/",
        "type": "civil_society",
        "description": "EDRi document pool on data retention and mass surveillance"
      },
      {
        "url": "https://verfassungsblog.de/data-retention/",
        "type": "civil_society",
        "description": "Legal analysis of CJEU data retention rulings and national implementations"
      }
    ],
    "notes": "Follows series of CJEU rulings (Digital Rights Ireland, Tele2 Sverige, La Quadrature du Net I & II) that progressively expanded member state leeway for data retention. Current proposal: (1) Impact assessment 2025; (2) Legislative proposal expected Q1 2026. Key concerns: (1) 'Lawful access by design' requirement - surveillance built into infrastructure; (2) Close coordination between state and industry for surveillance purposes; (3) CJEU allowed 'targeted retention' and IP address retention that member states have exploited. Belgium uses 'targeted retention' covering entire territory. France uses rotating short-term retention claiming continuous national security threat. Opposition: Digital rights groups argue data retention is 'stone dead' after Tele2 but being resurrected through exceptions. Workers' concern: Mass surveillance of communications chills union organizing and worker solidarity networks."
  },

